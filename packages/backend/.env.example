# Server
PORT=4000
NODE_ENV=development

# Database (MySQL)
DB_HOST=localhost
DB_PORT=3306
DB_NAME=flightprestige
DB_USER=flightprestige
DB_PASSWORD=password
DB_SYNC=true

# Auth
JWT_SECRET=change-me-in-production-min-32-chars
JWT_EXPIRES_IN=7d
COOKIE_SECURE=false

# Flight Data Providers
AMADEUS_API_KEY=
AMADEUS_API_SECRET=
AMADEUS_BASE_URL=https://test.api.amadeus.com

KIWI_API_KEY=
KIWI_BASE_URL=https://api.tequila.kiwi.com

# Notifications
RESEND_API_KEY=
RESEND_FROM_EMAIL=alerts@flightprestige.com

TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_FROM_PHONE=+1234567890

# Detection thresholds
INSANE_MULTIPLIER=1.2
GOOD_MULTIPLIER=1.5
ALERT_COOLDOWN_HOURS=24
MIN_CONSECUTIVE_DETECTIONS=2

# Logging
ENABLE_REQUEST_LOGGER=true
