{
  "name": "@flightprestige/backend",
  "version": "0.1.0",
  "private": true,
  "type": "commonjs",
  "scripts": {
    "dev": "sh -c 'lsof -ti:4000 | xargs kill -9 2>/dev/null; node --watch -r ts-node/register --require dotenv/config src/index.ts'",
    "worker": "node --watch -r ts-node/register --require dotenv/config src/workers/scheduler.worker.ts",
    "build": "tsc",
    "start": "node dist/index.js"
  },
  "dependencies": {
    "@flightprestige/shared": "*",
    "bcryptjs": "^2.4.3",
    "cookie-parser": "^1.4.6",
    "cors": "^2.8.5",
    "dotenv": "^16.4.0",
    "express": "^4.19.2",
    "express-rate-limit": "^7.3.1",
    "helmet": "^7.1.0",
    "jose": "^5.3.0",
    "morgan": "^1.10.0",
    "mysql2": "^3.9.7",
    "node-cron": "^3.0.3",
    "reflect-metadata": "^0.2.2",
    "resend": "^3.2.0",
    "swagger-jsdoc": "^6.2.8",
    "swagger-ui-express": "^5.0.1",
    "twilio": "^5.2.0",
    "typeorm": "^0.3.20"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.6",
    "@types/cookie-parser": "^1.4.7",
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/morgan": "^1.9.9",
    "@types/node": "^20.12.0",
    "@types/node-cron": "^3.0.11",
    "@types/swagger-jsdoc": "^6.0.4",
    "@types/swagger-ui-express": "^4.1.6",
    "ts-node": "^10.9.2",
    "tsx": "~4.19.0",
    "typescript": "^5.4.0"
  }
}
